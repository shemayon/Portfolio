# ===========================================
# LOCAL DEVELOPMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Web3Forms API Key for static contact form submissions.
# Get your free key instantly at: https://web3forms.com/
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_key_here
# Application URLs (local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CONTACT_EMAIL=test@example.com

# Skip environment validation during build (optional)
# SKIP_ENV_VALIDATION=true

# ===========================================
# DEPLOYMENT CONFIGURATION (CI/CD only)
# ===========================================
# These are set in GitHub Secrets/Variables, not locally.
# See docs/deployment/environments.md for details.
#
# GitHub Variables:
#   NEXT_PUBLIC_BASE_URL=https://your-domain.com
#   NEXT_PUBLIC_APP_URL=https://your-domain.com
#
# GitHub Secrets:
#   NEXT_PUBLIC_WEB3FORMS_KEY=your_production_key
