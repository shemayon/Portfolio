{
  "name": "shemayon-portfolio",
  "version": "3.7.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "predev": "node scripts/generate-static-image-variants.mjs",
    "dev": "next dev",
    "generate:csp-hashes": "node scripts/generate-next-inline-csp-hashes.mjs",
    "images:generate": "node scripts/generate-static-image-variants.mjs",
    "prebuild": "node scripts/generate-static-image-variants.mjs",
    "build": "next build",
    "start": "npx serve@latest out",
    "lint": "biome check . --write --error-on-warnings",
    "lint:md": "markdownlint '**/*.md' --dot --ignore-path .gitignore --ignore CHANGELOG.md",
    "lint:md:fix": "markdownlint '**/*.md' --dot --ignore-path .gitignore --ignore CHANGELOG.md --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "env:check": "node --input-type=module -e \"import('./src/env.mjs')\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:docker": "./scripts/run-e2e-tests.sh",
    "test:e2e:setup": "./scripts/setup-e2e.sh",
    "deploy:static:prod": "node scripts/deploy-static-site.mjs --env prod",
    "serve": "pnpm dlx serve out",
    "prepare": "husky",
    "analyze": "next experimental-analyze",
    "resend:status": "tsx scripts/ops/resend-domain-manager.ts status",
    "resend:records": "tsx scripts/ops/resend-domain-manager.ts records",
    "resend:verify": "tsx scripts/ops/resend-domain-manager.ts verify",
    "resend:sync-dns": "tsx scripts/ops/resend-domain-manager.ts sync-dns"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1004.0",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.72",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@t3-oss/env-nextjs": "^0.13.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "0.577.0",
    "next": "16.1.7",
    "nuqs": "^2.8.9",
    "pnpm": "^10.28.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.3",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-route-53": "^3.1003.0",
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "4.1.1",
    "commander": "^14.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "markdownlint-cli": "^0.48.0",
    "msw": "^2.12.10",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "shadcn-ui": "^0.9.5",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "~7.3.1",
    "vitest": "4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "overrides": {
    "flatted": "3.4.2"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "not dead"
  ]
}
